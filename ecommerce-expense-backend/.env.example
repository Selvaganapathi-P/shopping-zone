PORT=5000
MONGO_URI=mongodb://localhost:27017/thanselzovia
JWT_SECRET=your_jwt_secret_here
ADMIN_EMAIL=admin@example.com
ADMIN_SECRET_KEY=your_admin_secret_key

# Anthropic AI (for AI chat assistant and description generator)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Base URL for product image uploads
BASE_URL=http://localhost:5000

# Cloudinary (optional — images upload to CDN instead of local disk)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Nodemailer SMTP (optional — order confirmation emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_gmail@gmail.com
# SMTP_PASS=your_app_password

# Pexels API (for stock photo fetch in admin product form)
# PEXELS_API_KEY=your_pexels_api_key
